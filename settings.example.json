{
  "_description": "Optional local development settings. Do not put real secrets in git.",
  "ai": {
    "provider": "openrouter",
    "model": "google/gemini-2.0-flash-001",
    "temperature": 0.2,
    "max_tokens": 4000,
    "timeout_seconds": 90,
    "gemini_keys": [],
    "openrouter_keys": [],
    "groq_keys": []
  },
  "generation": {
    "default_style": "realistic",
    "default_complexity": 3,
    "default_folder": "default",
    "auto_save": true,
    "cache_enabled": true,
    "library_mode_default": false,
    "use_llm_geometry_planner": false,
    "geometry_planner_timeout": 6,
    "blender_timeout": 120
  },
  "quality": {
    "min_glb_size_bytes": 8192,
    "min_blender_vertices": 300,
    "min_blender_meshes": 3,
    "min_blender_primitives": 3
  },
  "blender": {
    "path": "",
    "version": "4.2",
    "export_format": "GLB"
  },
  "paths": {
    "models_dir": "models",
    "cache_dir": "models/cache",
    "presets_dir": "models/presets",
    "scripts_dir": "models/scripts",
    "storage_dir": "storage/users/user",
    "logs_dir": "logs",
    "static_dir": "static"
  }
}
